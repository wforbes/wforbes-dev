---
import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    role: "Lead Application Developer",
    company: "Russell Sigler, Inc",
    period: "Jan 2023 – Present",
    location: "Remote",
    highlights: [
      "Consolidated 23 microservices into a unified modular monorepo, reducing deployment time by 40%",
      "Designed event-driven enterprise notification engine serving 500+ concurrent users",
      "Led full infrastructure migration from AWS to on-prem, saving $20K/month while maintaining 99.9% uptime",
      "Resolved 100+ critical backlog issues and launched a triage workflow reducing bug turnaround by 60%",
    ],
  },
  {
    role: "Programmer II",
    company: "JT4, LLC (NGDC)",
    period: "Mar 2022 – Jan 2023",
    location: "Edwards AFB, CA",
    highlights: [
      "Modernized legacy C#/WPF system to Vue 3 + Quasar web platform across four Air Force bases",
      "Reverse-engineered existing codebase to extract core business logic for the new architecture",
      "Defined API contracts for flight test scheduling improving data accuracy and cross-system sync",
    ],
  },
  {
    role: "Programmer II",
    company: "IntegrITS Corp. (416th FLTS)",
    period: "Jan 2020 – Mar 2022",
    location: "Edwards AFB, CA",
    highlights: [
      "Modernized mission-critical Vue 1.5 app to Vue 2.0 with async/await and modular architecture",
      "Designed TypeScript data access layer abstracting SharePoint API complexity",
      "Built RBAC admin interface for compliance tracking of 200+ flight test personnel",
    ],
  },
  {
    role: "Configuration Specialist",
    company: "IntegrITS Corp. (412th CS)",
    period: "Dec 2018 – Jan 2020",
    location: "Edwards AFB, CA",
    highlights: [
      "Conducted enterprise security assessments identifying 50+ critical vulnerabilities across 10+ apps",
      "Increased automated test coverage from 10% to 50% for C#/VB.NET applications",
      "Established secure coding and QA practices adopted as organization-wide standards",
    ],
  },
];
---

<BaseLayout
  title="About | Will Forbes"
  description="Backend-focused full stack engineer with 7+ years of experience building scalable systems with Node.js, TypeScript, and cloud infrastructure."
>
  <section class="max-w-5xl mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-12">
    <!-- Page heading -->
    <div class="fade-up" style="animation-delay: 0.1s;">
      <div class="font-mono text-sm text-gray-500 mb-4">
        <span class="text-gray-600">$</span> cat ./about.md
      </div>
      <h1 class="font-mono text-3xl md:text-4xl font-bold text-gray-100">About</h1>
      <div class="h-px bg-accent mt-3 mb-8 w-32"></div>
    </div>

    <!-- Bio -->
    <div class="fade-up max-w-3xl space-y-4" style="animation-delay: 0.3s;">
      <p class="text-gray-300 leading-relaxed">
        I'm a backend-focused full stack engineer with over 7 years of experience
        designing and scaling systems that simplify complexity and drive measurable
        business impact. I specialize in modernizing architectures, consolidating
        microservices, and optimizing cloud infrastructure for reliability, cost,
        and performance.
      </p>
      <p class="text-gray-300 leading-relaxed">
        My career has taken me from enterprise security assessments at Edwards Air Force Base
        to leading full-stack development teams building event-driven systems serving hundreds
        of concurrent users. I hold an active U.S. DoD Secret Security Clearance and a
        Bachelor of Science in Software Engineering from Western Governor's University.
      </p>
      <p class="text-gray-300 leading-relaxed">
        I'm currently exploring <span class="text-accent-light font-medium">AI Engineering</span>
        — the development of applications that leverage foundation models to deliver
        AI-powered features. I see this as the next frontier in software engineering,
        and I'm building toward making it my specialty.
      </p>
    </div>

    <!-- Resume download -->
    <div class="mt-8 fade-up" style="animation-delay: 0.5s;">
      <a
        href="/wforbes_fullstack_resume_2026.pdf"
        target="_blank"
        class="inline-flex items-center gap-2 font-mono text-sm text-accent hover:text-accent-light transition-colors"
      >
        <span class="text-gray-500">&gt;</span> [download resume.pdf]
      </a>
    </div>
  </section>

  <!-- Experience timeline -->
  <section class="max-w-5xl mx-auto px-6 md:px-12 py-12 border-t border-border">
    <div class="fade-up" style="animation-delay: 0.1s;">
      <div class="font-mono text-sm text-gray-500 mb-6">
        <span class="text-gray-600">$</span> git log --oneline --career
      </div>
    </div>

    <div class="space-y-6">
      {experience.map((job, i) => (
        <div
          class="terminal-box rounded-lg p-5 md:p-6 fade-up"
          data-title={job.period}
          style={`animation-delay: ${0.2 + i * 0.15}s;`}
        >
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-3">
            <h3 class="font-mono text-lg font-semibold text-gray-100">{job.role}</h3>
            <span class="font-mono text-sm text-gray-500">{job.location}</span>
          </div>
          <p class="font-mono text-sm text-accent mb-4">{job.company}</p>

          <ul class="space-y-2">
            {job.highlights.map((h) => (
              <li class="flex gap-2 text-sm text-gray-400">
                <span class="text-gray-600 shrink-0">-</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Education -->
  <section class="max-w-5xl mx-auto px-6 md:px-12 py-12 border-t border-border">
    <div class="fade-up" style="animation-delay: 0.1s;">
      <div class="terminal-box rounded-lg p-5" data-title="education">
        <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
          <div>
            <h3 class="font-mono font-semibold text-gray-100">B.S. Software Engineering</h3>
            <p class="font-mono text-sm text-accent mt-1">Western Governor's University</p>
          </div>
          <span class="font-mono text-sm text-gray-500">2025</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
