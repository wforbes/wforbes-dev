---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title="Blog | Will Forbes"
  description="Articles on software engineering, AI engineering, and building production systems."
>
  <section class="max-w-5xl mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-12">
    <!-- Page heading -->
    <div class="fade-up" style="animation-delay: 0.1s;">
      <div class="font-mono text-sm text-gray-500 mb-4">
        <span class="text-gray-600">$</span> ls ./blog -la --sort=date
      </div>
      <h1 class="font-mono text-3xl md:text-4xl font-bold text-gray-100">Blog</h1>
      <div class="h-px bg-accent mt-3 mb-8 w-32"></div>
    </div>

    <!-- Tags filter -->
    {allTags.length > 0 && (
      <div class="fade-up mb-8" style="animation-delay: 0.3s;">
        <div class="flex flex-wrap gap-2">
          <a
            href="/blog"
            class="font-mono text-xs border rounded px-2 py-0.5 text-accent border-accent/30 hover:bg-accent/10 transition-colors"
          >
            all
          </a>
          {allTags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="font-mono text-xs text-gray-500 border border-border rounded px-2 py-0.5 hover:text-accent hover:border-accent/30 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Post listing -->
    <div class="grid gap-4">
      {posts.length > 0 ? (
        posts.map((post, i) => (
          <div class="fade-up" style={`animation-delay: ${0.3 + i * 0.1}s;`}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
            />
          </div>
        ))
      ) : (
        <div class="terminal-box rounded-lg p-6">
          <p class="font-mono text-gray-500">No posts found.</p>
        </div>
      )}
    </div>

    <!-- Post count -->
    <div class="mt-8 font-mono text-xs text-gray-600">
      {posts.length} post{posts.length !== 1 && "s"} found
    </div>
  </section>
</BaseLayout>
