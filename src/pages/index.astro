---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BlogCard from "../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Will Forbes | Software Engineer"
  description="Backend-focused full stack engineer specializing in Node.js, TypeScript, and cloud infrastructure."
>
  <Hero />

  <!-- Latest posts section -->
  <section class="max-w-5xl mx-auto px-6 md:px-12 py-12 border-t border-border">
    <div class="font-mono text-sm text-gray-500 mb-6">
      <span class="text-gray-600">$</span> ls ./blog --latest -n 3
    </div>

    <div class="grid gap-4">
      {latestPosts.length > 0 ? (
        latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))
      ) : (
        <div class="terminal-box rounded-lg p-5">
          <p class="font-mono text-gray-500">No posts yet. Check back soon.</p>
        </div>
      )}
    </div>

    <div class="mt-6">
      <a href="/blog" class="font-mono text-sm text-accent hover:text-accent-light transition-colors">
        [view all posts →]
      </a>
    </div>
  </section>
</BaseLayout>
