---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="Will Forbes | Software Engineer"
  description="Backend-focused full stack engineer specializing in Node.js, TypeScript, and cloud infrastructure. Building systems that simplify complexity."
>
  <Hero />

  <!-- Latest posts section — will be dynamic once blog system is built -->
  <section class="max-w-5xl mx-auto px-6 md:px-12 py-12 border-t border-border">
    <div class="font-mono text-sm text-gray-500 mb-6">
      <span class="text-gray-600">$</span> ls ./blog --latest
    </div>

    <div class="grid gap-4">
      <div class="terminal-box rounded-lg p-5" data-title=".mdx">
        <div class="flex items-baseline justify-between mb-2">
          <span class="font-mono text-gray-100 font-medium">Coming soon</span>
          <span class="font-mono text-xs text-gray-600">2026-03-04</span>
        </div>
        <p class="text-gray-400 text-sm">
          Blog posts about software engineering, AI engineering, and tech industry insights will appear here.
        </p>
        <div class="mt-3">
          <a href="/blog" class="font-mono text-xs text-accent hover:text-accent-light transition-colors">
            [view all posts →]
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
