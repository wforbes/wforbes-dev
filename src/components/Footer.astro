---
const socialLinks = [
  { href: "https://linkedin.com/in/wforbes87", label: "linkedin" },
  { href: "https://github.com/wforbes", label: "github" },
  { href: "https://bsky.app/profile/wforbes.dev", label: "bluesky" },
  { href: "https://x.com/wforbes87", label: "x" },
  { href: "https://medium.com/@wforbes", label: "medium" },
  { href: "mailto:wforbes87@gmail.com", label: "email" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-5xl mx-auto px-6 md:px-12 py-8">
    <div class="flex flex-col gap-4">
      <div class="font-mono text-sm text-gray-500">
        <span class="text-gray-600">$</span> find . -name "will-forbes" -type contact
      </div>

      <div class="flex flex-wrap gap-4">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("mailto") ? undefined : "_blank"}
            rel={link.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
            class="font-mono text-sm text-gray-400 hover:text-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="font-mono text-xs text-gray-600 mt-2">
        &copy; {year} Will Forbes. Built with Astro.
      </div>
    </div>
  </div>
</footer>
