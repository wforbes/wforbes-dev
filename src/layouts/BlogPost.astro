---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;

const formattedPubDate = pubDate.toISOString().split("T")[0];
const formattedUpdateDate = updatedDate?.toISOString().split("T")[0];
---

<BaseLayout title={`${title} | Will Forbes`} description={description}>
  <article class="max-w-3xl mx-auto px-6 md:px-12 pt-16 md:pt-24 pb-12">
    <!-- Post header -->
    <div class="fade-up" style="animation-delay: 0.1s;">
      <div class="font-mono text-sm text-gray-500 mb-4">
        <a href="/blog" class="hover:text-accent transition-colors">&lt;- back to blog</a>
      </div>

      <h1 class="font-mono text-2xl md:text-3xl font-bold text-gray-100 leading-tight">
        {title}
      </h1>
      <div class="h-px bg-accent mt-3 mb-4 w-24"></div>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 font-mono text-sm text-gray-500">
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {formattedUpdateDate && (
          <span class="text-gray-600">
            (updated {formattedUpdateDate})
          </span>
        )}
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3">
          {tags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="font-mono text-xs text-accent-dim border border-accent-dim/30 rounded px-2 py-0.5 hover:text-accent hover:border-accent/30 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Post content -->
    <div class="mt-10 fade-up prose-terminal" style="animation-delay: 0.3s;">
      <slot />
    </div>

    <!-- Footer nav -->
    <div class="mt-16 pt-8 border-t border-border fade-up" style="animation-delay: 0.1s;">
      <a
        href="/blog"
        class="font-mono text-sm text-accent hover:text-accent-light transition-colors"
      >
        [&lt;- all posts]
      </a>
    </div>
  </article>
</BaseLayout>
